# 翻译 API 配置
# 翻译后端: microsoft / deepl / none
TRANSLATOR_API=microsoft

# Microsoft Translator (推荐，免费 200万字符/月)
# 注册地址: https://portal.azure.com → 创建"Translator"资源 → F0 免费层
MS_TRANSLATOR_KEY=your_key_here
MS_TRANSLATOR_REGION=eastasia

# DeepL API (备选，免费 50万字符/月)
# 注册地址: https://www.deepl.com/pro-api
# DEEPL_API_KEY=your_key_here
